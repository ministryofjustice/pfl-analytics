# Virtual environment
venv/

# Input data files (but keep directory structure)
input/*
!input/.gitkeep
!input/README.md

# Output data files (but keep directory structure)
output/*
!output/.gitkeep

# Python cache
__pycache__/
*.py[cod]
*$py.class

# Environment variables (never commit proxy URLs or secrets)
.env
.env.*

# OS files
.DS_Store
*.swp
*.swo

# Excel temporary files
~$*.xlsx
~$*.xls
